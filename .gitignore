# =============================================================================
# XVA Engine .gitignore
# =============================================================================

# --- Python runtime ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environment ---
.venv/
venv/
env/
ENV/

# --- uv / pip ---
# Keep uv.lock committed for reproducibility
# uv.lock

# --- Testing & coverage ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# --- Engine runtime outputs ---
# All generated run artifacts (NPY, parquet, JSON configs, MD reports)
output/

# --- IDE / editor ---
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Type checking ---
.mypy_cache/
.ruff_cache/

# --- OS ---
.DS_Store
desktop.ini
